<!-- backdrop modal login/registro -->
<div id="modal-login-backdrop" class="fixed inset-0 bg-brand-dark/50 backdrop-blur-sm z-50 opacity-0 pointer-events-none transition-opacity duration-300"></div>

<!-- Modal Login/Registro -->
<div id="modal-login" class="fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transform scale-95 transition-all duration-300">

    <div class="bg-white w-full max-w-sm rounded-3xl shadow-2xl flex flex-col overflow-hidden">

        <div class="p-5 pb-2 flex justify-between items-center z-10">
            <h3 id="titulo-modal-login" class="font-bold text-brand-primary text-2xl tracking-tight">Bienvenido</h3>
            <button id="btn-cerrar-login" class="text-gray-400 hover:text-brand-accent p-1 transition-colors bg-gray-50 hover:bg-brand-light/10 rounded-full">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="px-5 mt-2">
            <div class="flex p-1 bg-gray-100 rounded-xl">
                <button id="tab-login" class="flex-1 py-2 text-sm font-bold bg-white text-brand-primary rounded-lg shadow-sm transition-all">Iniciar Sesión</button>
                <button id="tab-registro" class="flex-1 py-2 text-sm font-medium text-gray-500 hover:text-gray-700 rounded-lg transition-all">Crear Cuenta</button>
            </div>
        </div>

        <div class="p-5 pt-4">

            <div id="alerta-auth" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-xl flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-red-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                <p id="texto-alerta-auth" class="text-sm text-red-600 font-medium leading-tight"></p>
            </div>

            <form id="form-login" class="flex flex-col gap-4">

                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-1.5 ml-1">Usuario</label>
                    <input type="text" id="login-username" placeholder="Tu nombre de usuario" class="input-auth w-full bg-gray-50 border border-gray-200 text-gray-800 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-transparent transition-all" required>
                </div>

                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-1.5 ml-1">Contraseña</label>
                    <input type="password" id="login-password" placeholder="••••••••" class="input-auth w-full bg-gray-50 border border-gray-200 text-gray-800 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-transparent transition-all" required>
                </div>
                
                <button type="submit" class="w-full bg-brand-primary text-white font-bold rounded-xl px-4 py-3 mt-2 hover:bg-brand-dark transition-colors shadow-lg shadow-brand-primary/30">
                    Entrar
                </button>
            </form>

            <form id="form-registro" class="hidden flex flex-col gap-3">

                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-1 ml-1">Correo Electrónico</label>
                    <input type="email" id="reg-email" placeholder="tu@email.com" class="input-auth w-full bg-gray-50 border border-gray-200 text-gray-800 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-transparent transition-all" required>
                </div>

                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-1 ml-1">Usuario</label>
                    <input type="text" id="reg-username" placeholder="Elige un apodo" class="input-auth w-full bg-gray-50 border border-gray-200 text-gray-800 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-transparent transition-all" required>
                </div>

                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-1 ml-1">Contraseña</label>
                    <input type="password" id="reg-password" placeholder="Mínimo 6 caracteres" class="input-auth w-full bg-gray-50 border border-gray-200 text-gray-800 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-transparent transition-all" required>
                </div>

                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-1 ml-1">Repetir Contraseña</label>
                    <input type="password" id="reg-password-confirm" placeholder="Vuelve a escribirla" class="input-auth w-full bg-gray-50 border border-gray-200 text-gray-800 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-transparent transition-all" required>
                </div>
                
                <button type="submit" class="w-full bg-brand-accent text-white font-bold rounded-xl px-4 py-3 mt-2 hover:opacity-90 transition-colors shadow-lg shadow-brand-accent/30">
                    Crear Cuenta
                </button>

            </form>

        </div>
    </div>
</div>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FindMyCar</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel='stylesheet' href='/stylesheets/style.css' />

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-gray-50 flex flex-col h-screen font-sans text-brand-dark overflow-hidden">

  <!-- Header -->
  <header class="bg-white shadow-sm p-2 flex justify-between items-center z-10 relative">
    <div class="text-xl font-bold text-brand-primary tracking-tight flex items-center gap-2">
      <span class="text-brand-accent">📍</span> FindMyCar
    </div>
    
    <button id="btn-abrir-menu" class="text-brand-primary p-2 rounded-lg hover:bg-brand-light/30 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </header>

  <!-- Main Content -->
  <main class="grow relative bg-gray-200">
    
    <div id="map" class="w-full h-full z-0"></div>
    
    <div id="map-overlay" class="absolute inset-0 bg-slate-800/40 backdrop-blur-3px z-500 transition-opacity duration-500"></div>

    <div id="panel-info" class="hidden absolute top-6 left-1/2 -translate-x-1/2 z-999 w-auto min-w-240px max-w-90% bg-white/30 backdrop-blur-md px-4 py-2 rounded-2xl shadow-md border border-white/50 flex flex-row justify-evenly items-center transition-all duration-300">

      <div class="flex flex-col items-center w-1/2">
        <span class="text-gray-600 text-8px uppercase tracking-wider font-extrabold mb-0.5">Distancia</span>
        <span id="info-distancia" class="text-brand-primary font-black text-lg leading-none">-- m</span>
      </div>

      <div class="h-9 w-px bg-gray-600 mx-4"></div>

      <div class="flex flex-col items-center w-1/2">
        <span class="text-gray-600 text-9px uppercase tracking-wider font-extrabold mb-0.5">Tiempo</span>
        <span id="info-tiempo" class="text-brand-accent font-black text-lg leading-none">-- min</span>
      </div>

    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-999 w-11/12 max-w-sm">
      <button id="btn-aparcar" class="w-full bg-brand-primary text-white py-4 rounded-2xl shadow-xl font-bold text-lg flex items-center justify-center gap-2 active:bg-brand-secondary transition-colors disabled:opacity-70 disabled:cursor-not-allowed">
        Aparcar Aquí
      </button>
    </div>

  </main>

  <!-- backdrop del menu offcanvas -->
  <div id="menu-backdrop" class="fixed inset-0 bg-brand-dark/40 backdrop-blur-sm z-3000 opacity-0 pointer-events-none transition-opacity duration-300"></div>

  <div id="menu-lateral" class="fixed top-0 right-0 h-full w-68 bg-white z-3010 shadow-2xl transform translate-x-full transition-transform duration-300 flex flex-col">
    
    <div class="p-5 flex justify-between items-center border-b border-gray-100">
      <span class="font-bold text-brand-primary text-lg">Mi Cuenta</span>
      <button id="btn-cerrar-menu" class="text-gray-400 hover:text-brand-accent p-1 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="p-4 flex flex-col gap-3">
      <button id="btn-login" class="w-full bg-brand-light/10 text-brand-primary border border-brand-light px-4 py-3 rounded-xl font-medium flex items-center gap-3 hover:bg-brand-light/20 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
        Iniciar Sesión / Registro
      </button>

      <button id="btn-historial" class="w-full bg-gray-50 text-gray-700 border border-gray-200 px-4 py-3 rounded-xl font-medium flex items-center gap-3 hover:bg-gray-100 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        Mis Aparcamientos
      </button>
    </div>

  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="/javascripts/interfaz.js"></script>
  <script src="/javascripts/mapa.js"></script>
</body>
</html>